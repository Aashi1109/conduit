NODE_ENV=development
PORT=3000

# Postgres connection for Sequelize
DATABASE_URL=postgresql://postgres:password@localhost:5432/api_proxy

# Express limits
EXPRESS_FILE_SIZE_LIMIT=50mb

# CORS configuration
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_CREDENTIALS=false

# Logging
LOG_ALL_LOGS_PATH=./logs/server.log
LOG_ERROR_LOGS_PATH=./logs/error.log

# Webhook configuration
WEBHOOK_URL=https://your-service.com/hooks/api-proxy
WEBHOOK_SECRET=long-random-secret

# Internal token shared with upstream services
INTERNAL_SECRET=another-long-random-secret

# Refresh token lifetime (in days)
REFRESH_TOKEN_TTL_DAYS=90

# Dynamic proxy upstreams (add more as needed)
PROXY_SERVICE_CONVERTER_URL=http://localhost:4001
PROXY_SERVICE_PAYMENTS_URL=http://localhost:4002

# API Authentication Skip Paths
# Comma-separated list of paths (relative to service mount) that bypass API key authentication.
# Defaults to /docs if not set.
AUTH_SKIP_PATHS=/docs,/healthz

# Deployed service URL shown as a server entry in Swagger UI.
# Set automatically by Cloud Run; override locally if needed.
# CLOUD_RUN_SERVICE_URL=https://your-service-abc123-uc.a.run.app
